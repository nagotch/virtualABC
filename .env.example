# サーバー
PORT=3000
TRAQ_CLIENT_ID=your_oauth2_client_id
TRAQ_REDIRECT_URI=http://localhost:3000/api/auth/callback
# フロントのURL（通知メッセージ内のリンクに使用）
APP_URL=http://localhost:5173
# レート変動ありのコンテストを作成できる管理者のtraQ ID（カンマ区切り）。未設定なら nagotch のみ。
ADMIN_TRAQ_IDS=nagotch

# Bot（コンテスト作成通知に使用）
TOKEN=your_bot_access_token_here
BOT_NAME=BOT_nagotch_virtual
# 通知を投稿するtraQチャンネルID（BOTが参加しているチャンネル）
TRAQ_NOTIFY_CHANNEL_ID=your_channel_uuid_here
