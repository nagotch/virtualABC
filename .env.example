# サーバー
PORT=3000

# データベース（MariaDB / MySQL）
# 本番(NeoShowcase)では NS_MARIADB_HOSTNAME などが自動注入されるため設定不要。
# ローカル開発では下記 DB_* で接続先を指定する（未設定なら 127.0.0.1:3306 / root / nagotch_virtual）。
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=nagotch_virtual
# traQ OAuth2 クライアント（https://bot-console.trap.jp 等で発行）
TRAQ_CLIENT_ID=your_oauth2_client_id
TRAQ_CLIENT_SECRET=your_oauth2_client_secret
# 認証コールバックURL。本番は https://<your-host>/api/auth/callback を指定し、
# traQ側のクライアント設定にも同じURLを許可リダイレクトとして登録すること。
TRAQ_REDIRECT_URI=http://localhost:3000/api/auth/callback
# フロントのURL（認証後の戻り先・CORS許可元・通知メッセージ内リンクに使用）
# 本番は https://<your-host> を指定。
APP_URL=http://localhost:5173
# レート変動ありのコンテストを作成できる管理者のtraQ ID（カンマ区切り）。未設定なら nagotch のみ。
ADMIN_TRAQ_IDS=nagotch

# Bot（コンテスト作成通知に使用）
TOKEN=your_bot_access_token_here
BOT_NAME=BOT_nagotch_virtual
# 通知を投稿するtraQチャンネルID（BOTが参加しているチャンネル）
TRAQ_NOTIFY_CHANNEL_ID=your_channel_uuid_here
